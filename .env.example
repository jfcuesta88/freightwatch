# ──────────────────────────────────────────────
# FreightWatch API Configuration
# Copy this file to .env and fill in your keys
# ──────────────────────────────────────────────

# Option 1: Data Docked (FREE tier, 20 credits) — datadocked.com
REACT_APP_DATADOCKED_KEY=your_datadocked_api_key

# Option 2: AISHub (FREE, requires AIS receiver) — aishub.net
REACT_APP_AISHUB_USERNAME=your_aishub_username

# Option 3: MarineTraffic (paid ~$50/mo) — marinetraffic.com
REACT_APP_MARINETRAFFIC_KEY=your_marinetraffic_key

# The app tries MarineTraffic first, then AISHub, then Data Docked, then simulation
